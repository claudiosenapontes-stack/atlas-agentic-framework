// Prisma schema for ATLAS Mission Control

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum MissionStatus {
  NEW
  ACTIVE
  BLOCKED
  REVIEW
  DONE
  CANCELED
}

enum RunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?

  managerAgentId String? @unique
  managerAgent   Agent?    @relation("TeamManager", fields: [managerAgentId], references: [id])

  agents   Agent[]
  missions Mission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agent {
  id          String  @id @default(cuid())
  name        String
  role        String? // e.g. "Manager", "Research", "Ops"
  persona     String? // freeform system/persona text
  voice       String? // optional voice profile key/name
  toolsJson   String? // JSON array/string describing allowed tools/APIs
  trainingJson String? // JSON describing training pack pointers
  isActive    Boolean @default(true)

  teamId String?
  team   Team?    @relation(fields: [teamId], references: [id])

  // reverse relation for Team.managerAgent
  managesTeam Team? @relation("TeamManager")

  runs Run[]
  ownedMissions Mission[] @relation("MissionOwner")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, name])
}

model Mission {
  id          String        @id @default(cuid())
  title       String
  objective   String?
  constraints String?
  priority    Int           @default(3) // 1=high,5=low
  status      MissionStatus @default(NEW)
  deadlineAt  DateTime?

  teamId String?
  team   Team? @relation(fields: [teamId], references: [id])

  ownerAgentId String?
  ownerAgent   Agent? @relation("MissionOwner", fields: [ownerAgentId], references: [id])

  tasks     MissionTask[]
  runs      Run[]
  notes     Note[]
  artifacts Artifact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, priority])
}

model MissionTask {
  id        String  @id @default(cuid())
  missionId String
  mission   Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  title     String
  done      Boolean @default(false)
  order     Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([missionId, order])
}

model Run {
  id        String    @id @default(cuid())
  missionId String
  mission   Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)

  agentId String?
  agent   Agent?  @relation(fields: [agentId], references: [id])

  status   RunStatus @default(QUEUED)
  startedAt DateTime?
  finishedAt DateTime?

  // Link to OpenClaw execution context when we wire it up
  sessionKey String?

  logs      LogEvent[]
  artifacts Artifact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([missionId, createdAt])
  @@index([status])
}

model LogEvent {
  id     String @id @default(cuid())
  runId  String
  run    Run    @relation(fields: [runId], references: [id], onDelete: Cascade)

  level  String @default("info") // info|warn|error|tool
  message String
  metaJson String?

  createdAt DateTime @default(now())

  @@index([runId, createdAt])
}

model Artifact {
  id        String @id @default(cuid())
  missionId String?
  mission   Mission? @relation(fields: [missionId], references: [id], onDelete: Cascade)

  runId String?
  run   Run?   @relation(fields: [runId], references: [id], onDelete: Cascade)

  kind  String // file|link|note|image
  name  String
  uri   String // file path or URL

  createdAt DateTime @default(now())

  @@index([missionId])
  @@index([runId])
}

model Note {
  id        String @id @default(cuid())
  missionId String
  mission   Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  author    String? // "Claudio", agent name, etc.
  body      String

  createdAt DateTime @default(now())
}
